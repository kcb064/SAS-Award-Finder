# EuroBonus Award Finder — configuration. Copy to `.env` and edit. `.env` is git-ignored.
# Every setting has a safe default; you usually only need HOME_AIRPORTS and the notify URLs.

# --- Core ---
# Comma-separated IATA codes you fly out of. First one is the default in the UI.
AF_HOME_AIRPORTS=CPH

# Where the app writes its SQLite DB, browser profile, and raw snapshots.
AF_DATA_DIR=./data

# HTTP port the app listens on (uncommon by design to avoid stack collisions).
AF_PORT=8617

# --- Provider (Phase 4) ---
# 'sas_direct' (default) scrapes SAS's public feed via real Chrome. 'seats_aero' switches to the
# seats.aero Partner API (Pro subscription, ~$10/mo) — the fallback if SAS blocks scraping, and
# the only path to SkyTeam partner award space. Requires the API key below.
AF_PROVIDER=sas_direct
AF_SEATS_AERO_API_KEY=

# --- Fetching (SAS direct via real Chrome) ---
# Run Chrome headless (true on a server). Set false only for local debugging with a display.
AF_HEADLESS=true
# Playwright browser channel. MUST be real Google Chrome — bundled Chromium is Cloudflare-blocked.
AF_BROWSER_CHANNEL=chrome
# Polite pacing between SAS requests (seconds, jittered between min and max).
AF_FETCH_MIN_INTERVAL_S=4
AF_FETCH_MAX_INTERVAL_S=8
# Hard daily cap on SAS requests (network + route feeds combined).
AF_DAILY_REQUEST_BUDGET=500
# How long a cached snapshot is considered fresh before a refetch (seconds). Endpoint caches 600s.
AF_SNAPSHOT_TTL_S=900
# Days of raw snapshot files + observation history to keep (a daily prune job enforces this;
# each route's newest snapshot always survives).
AF_SNAPSHOT_RETENTION_DAYS=30

# --- Voucher / value ---
# How many SAS Amex 2-for-1 vouchers you hold (informational; used in UI hints).
AF_VOUCHER_COUNT=1

# --- Watches / alerts (Phase 2) ---
# How often the background sweep re-checks every enabled watch (minutes). One SAS request per
# watched route per sweep (watches on the same route share it).
AF_WATCH_REFRESH_MINUTES=60
# Undelivered alerts are retried on this cadence until they send (minutes).
AF_ALERT_RETRY_MINUTES=5
# Consecutive sweep failures on a route before an ops alert fires.
AF_OPS_FAILURE_THRESHOLD=3

# --- Explore (Phase 3) ---
# Max route fetches the nightly Explore sweep may spend, per origin. Cached route snapshots are
# reused for free, and watches always keep budget priority over Explore.
AF_EXPLORE_SWEEP_BUDGET=25
# Center of the nightly sweep window (UTC hour); actual start is jittered ±2h around it.
AF_EXPLORE_SWEEP_HOUR_UTC=4
# Stay window (days) Explore pairs round-trip leads within.
AF_EXPLORE_MIN_STAY_DAYS=3
AF_EXPLORE_MAX_STAY_DAYS=14

# --- Notifications (Apprise URLs, comma-separated). Examples:
#   tgram://BOT_TOKEN/CHAT_ID          (Telegram)
#   discord://WEBHOOK_ID/WEBHOOK_TOKEN (Discord)
#   ntfy://TOPIC or ntfys://host/TOPIC (ntfy)
AF_NOTIFY_URLS=

# --- Optional basic-auth gate (if not fronting with Cloudflare Access).
# Leave both empty to disable. If set, the whole UI requires this user/pass.
AF_BASIC_AUTH_USER=
AF_BASIC_AUTH_PASS=

# --- Scheduler ---
# Enable the background snapshot-refresh scheduler. Phase 1 keeps it minimal.
AF_SCHEDULER_ENABLED=true
